# === Serveur ===
PORT=3001
NODE_ENV=development

# === Base de données MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=trouve_ton_artisan
DB_USER=root
DB_PASSWORD=

# === CORS ===
CORS_ORIGIN=http://localhost:3000

# === Email (Nodemailer / SMTP) ===
# Pour tester en dev : utilisez Mailtrap (https://mailtrap.io)
# Pour la production : configurez un vrai service SMTP (Brevo, OVH, Gmail, etc.)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Trouve ton artisan <noreply@trouvetonartisan.fr>"